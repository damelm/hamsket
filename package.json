{
	"name": "hamsket",
	"productName": "OpsDesk",
	"version": "1.1.0",
	"description": "Internal multi-service messaging hub (WhatsApp, Telegram, Slack, Nextcloud Talk, Element + custom URLs) in one window.",
	"main": "./out/main/index.js",
	"type": "module",
	"private": true,
	"author": "Damian Peña (https://github.com/damelm)",
	"license": "GPL-3.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/damelm/hamsket.git"
	},
	"homepage": "https://github.com/damelm/hamsket",
	"bugs": {
		"url": "https://github.com/damelm/hamsket/issues"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"scripts": {
		"dev": "electron-vite dev",
		"build": "electron-vite build",
		"start": "electron-vite preview",
		"typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
		"lint": "eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest run",
		"test:e2e": "playwright test",
		"test": "npm run test:unit && npm run test:e2e",
		"pack": "npm run build && electron-builder --dir",
		"dist": "npm run build && electron-builder"
	},
	"dependencies": {
		"@electron-toolkit/utils": "^4.0.0",
		"auto-launch": "^5.0.6",
		"electron-context-menu": "^4.1.2",
		"electron-store": "^11.0.2",
		"electron-updater": "^6.8.9",
		"preact": "^10.29.3"
	},
	"devDependencies": {
		"@electron-toolkit/tsconfig": "^2.0.0",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.61.1",
		"@preact/preset-vite": "^2.10.5",
		"@types/node": "^24.0.0",
		"electron": "^43.0.0",
		"electron-builder": "^26.15.3",
		"electron-vite": "^5.0.0",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.5",
		"eslint-plugin-react-hooks": "^7.1.1",
		"globals": "^17.7.0",
		"prettier": "^3.9.4",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.1",
		"vite": "^7.3.6",
		"vitest": "^4.1.9"
	}
}
