{
	"extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
	"include": ["src/renderer/src/**/*", "src/preload/**/*", "src/shared/**/*"],
	"compilerOptions": {
		"composite": true,
		"jsxImportSource": "preact",
		"paths": {
			"@renderer/*": ["./src/renderer/src/*"],
			"@shared/*": ["./src/shared/*"]
		}
	}
}
