{
	"productName": "OpsDesk",
	"appId": "com.damelm.hamsket",
	"asar": true,
	"publish": {
		"provider": "github",
		"owner": "damelm",
		"repo": "hamsket",
		"releaseType": "release"
	},
	"files": ["out/**/*", "package.json"],
	"extraResources": [{ "from": "resources", "to": "resources" }],
	"mac": {
		"category": "public.app-category.productivity",
		"target": ["default"]
	},
	"dmg": {
		"title": "OpsDesk",
		"iconSize": 128,
		"contents": [
			{
				"x": 355,
				"y": 125,
				"type": "link",
				"path": "/Applications"
			},
			{
				"x": 155,
				"y": 125,
				"type": "file"
			}
		]
	},
	"win": {
		"target": ["nsis"]
	},
	"nsis": {
		"oneClick": false,
		"perMachine": false,
		"allowToChangeInstallationDirectory": true,
		"createDesktopShortcut": true,
		"createStartMenuShortcut": true,
		"runAfterFinish": true
	},
	"linux": {
		"category": "Network",
		"target": ["tar.gz", "deb", "rpm", "AppImage"]
	},
	"directories": {
		"buildResources": "resources/installer/",
		"output": "dist/"
	}
}
